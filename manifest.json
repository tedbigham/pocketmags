{
  "manifest_version": 2,
  "name": "Magazine Bin to PDF",
  "version": "1.0.0",
  "description": "Detect numbered magazine .bin image requests and download them as a PDF.",
  "browser_specific_settings": {
    "gecko": {
      "id": "{59953640-adbc-439d-9c38-e0ca5b0939af}"
    }
  },
  "permissions": [
    "webRequest",
    "downloads",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["dist/background.js"]
  },
  "browser_action": {
    "default_title": "Magazine PDF",
    "default_popup": "src/popup.html"
  }
}
